{
  "compilerOptions": {
    "target": "ES2022",                      
    "module": "CommonJS",                    
    "lib": ["ES2022", "DOM"],                 
    "allowJs": true,                          
    "checkJs": false,                       

    "outDir": "./dist",                      
    "rootDir": "./",                           
    "strict": true,                           
    "esModuleInterop": true,                    
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,                   
    "resolveJsonModule": true,              
    "allowSyntheticDefaultImports": true,  
    "moduleResolution": "node",             
    "types": ["node"],                      
    "noImplicitAny": false                
  },
  "include": ["index.ts", "src", "prisma"],
  "exclude": ["node_modules", "dist"]
}