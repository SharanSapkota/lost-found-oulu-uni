{
  "compilerOptions": {
    "target": "ES2022",                     // Modern JS output
    "module": "CommonJS",                   // Node.js modules
    "lib": ["ES2022", "DOM"],               // Modern JS + DOM
    "allowJs": true,                        // Allow .js files
    "checkJs": false,                       

    "outDir": "./dist",                     // Compiled files output
    "rootDir": "./",                        // Root folder for TS files
    "strict": true,                         // Enable all strict checks
    "esModuleInterop": true,                // For proper imports of commonjs modules
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,                   // Skip type check for node_modules
    "resolveJsonModule": true,              // Allow importing JSON files
    "allowSyntheticDefaultImports": true,   // Allow default imports from CommonJS
    "moduleResolution": "node",             // Node module resolution
    "types": ["node"],                       // Include node types
    "noImplicitAny": false                  // Relax 'any' restrictions (optional)
  },
  "include": ["src", "prisma"],            // Your source and Prisma folders
  "exclude": ["node_modules", "dist"]
}